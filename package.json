{
  "name": "sepay-integration",
  "version": "1.0.0",
  "description": "PaymentOrder management service — Sepay integration ready",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "migration:generate": "typeorm-ts-node-commonjs -d database/data-source.ts migration:generate database/migrations/$npm_config_name",
    "migration:create": "typeorm-ts-node-commonjs migration:create database/migrations/$npm_config_name",
    "migration:run": "typeorm-ts-node-commonjs -d database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d database/data-source.ts migration:revert"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mysql2": "^3.9.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sepay-pg-node": "^1.0.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
